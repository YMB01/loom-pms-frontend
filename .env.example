APP_NAME=LoomPMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Production: copy .env.production.example and set APP_ENV=production, APP_DEBUG=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=loom_pms
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queues (SMS jobs, etc.)
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Sanctum (SPA / cookie auth; comma-separated hosts)
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000

# CORS — production: comma-separated Next.js origins (required when APP_DEBUG=false).
# Local dev: config/cors.php allows * when APP_ENV=local or APP_DEBUG=true.
# Example production:
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Africa's Talking SMS
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=

# Twilio SMS (fallback)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# SMS helpers (optional)
SMS_DEFAULT_COUNTRY_CODE=251

# WhatsApp (Meta Cloud API — optional; outbound rows stored in whatsapp_logs via WhatsAppMessagingService)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Super Admin (system owner — not stored in DB; separate Bearer token from Sanctum)
SUPER_ADMIN_EMAIL=superadmin@loomsolutions.com
SUPER_ADMIN_PASSWORD=admin123
# Optional: session length (hours)
SUPER_ADMIN_TOKEN_TTL_HOURS=8

# Stripe (company SaaS subscriptions — create Products/Prices in Stripe Dashboard)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Recurring monthly price IDs for Basic ($29) and Pro ($79)
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=

# Next.js app URL (Stripe Checkout success/cancel and billing portal return)
FRONTEND_URL=http://localhost:3000
